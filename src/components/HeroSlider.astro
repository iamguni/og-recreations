---
import { getCollection } from 'astro:content';
const slides = await getCollection('sliders');
---
<div class="relative overflow-hidden bg-brand-blue h-[600px]">
  <div class="relative w-full h-full">
    {slides.map((slide, index) => (
      <div class={`slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100 z-20' : 'opacity-0 z-0'}`}>
        <div class="absolute inset-0 bg-gradient-to-r from-brand-blue via-brand-blue/80 to-transparent z-10"></div>
        <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${slide.data.image}');`}></div>
        <div class="absolute inset-0 z-20 flex items-center max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl text-white">
            <span class="inline-block bg-brand-gold/20 text-brand-gold px-3 py-1 rounded-full text-xs font-bold tracking-widest uppercase mb-4 border border-brand-gold/40">{slide.data.tagline}</span>
            <h1 class="font-serif text-4xl sm:text-6xl font-bold tracking-wide leading-tight mb-6">{slide.data.headline}</h1>
            <a href={slide.data.ctaUrl} class="inline-block bg-brand-gold hover:bg-brand-goldHover text-brand-blue font-bold px-8 py-3.5 rounded-lg shadow-lg transition">{slide.data.ctaText}</a>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-30 flex space-x-3">
    {slides.map((_, i) => (
      <button class={`dot w-3 h-3 rounded-full ${i === 0 ? 'bg-brand-gold' : 'bg-white/40'}`} onclick={`setSlide(${i})`}></button>
    ))}
  </div>
</div>
<script is:inline>
  let currentSlide = 0;
  window.setSlide = function(index) {
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');
    slides.forEach((slide, i) => {
      slide.style.opacity = i === index ? '1' : '0';
      slide.style.zIndex = i === index ? '20' : '0';
    });
    dots.forEach((dot, i) => {
      dot.className = i === index ? 'dot w-3 h-3 rounded-full bg-brand-gold' : 'dot w-3 h-3 rounded-full bg-white/40';
    });
    currentSlide = index;
  }
  setInterval(() => {
    const slides = document.querySelectorAll('.slide');
    if(slides.length > 0) {
      let next = (currentSlide + 1) % slides.length;
      window.setSlide(next);
    }
  }, 5000);
</script>