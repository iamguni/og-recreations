---
import footerConfig from '../data/footer.json';
import socialsData from '../data/socials.json';

// Fetch dynamic channels list safely from updated JSON structure
const activeSocials = socialsData?.channels || [];
---
<footer class="bg-brand-blue text-gray-300 pt-16 pb-8 border-t-4 border-brand-gold mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    {footerConfig.columnSequence.map((col) => (
      <div>
        <h3 class="font-serif text-lg font-bold text-white tracking-wide border-b border-brand-gold/30 pb-2 mb-4">
          {col.columnTitle}
        </h3>
        {col.columnText && ( <p class="text-sm leading-relaxed text-gray-400 mb-3">{col.columnText}</p> )}
        
        {col.columnLinks && (
          <ul class="space-y-2 text-sm font-medium mb-3">
            {col.columnLinks.map((link) => (
              <li><a href={link.linkUrl} class="hover:text-brand-gold transition duration-150">{link.linkLabel}</a></li>
            ))}
          </ul>
        )}

        <!-- 🕒 Dynamic Extra Text Field Option Injected Natively Below Column Elements -->
        {col.extraText && (
          <div class="pt-2 mt-2 border-t border-white/10 text-gray-400 flex items-start gap-2">
            <div class="text-xs font-medium leading-relaxed">
              <span class="block text-[10px] uppercase tracking-wider text-brand-gold font-bold mb-0.5">{col.extraColumnTitle}</span>
              {col.extraText}
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-6 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
    
    <!-- Dynamic Social Media Vector Icons (Replaces old text links) -->
    <div class="flex space-x-5">
      {activeSocials.map((social) => (
        <a 
          href={social.url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-gray-400 hover:text-brand-gold transition-colors duration-200"
          title={`Follow our ${social.platform}`}
        >
          {social.platform === 'facebook' && <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.8z"/></svg>}
          {social.platform === 'instagram' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>}
          {social.platform === 'twitter' && <svg class="w-4 h-4 mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>}
          {social.platform === 'linkedin' && <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>}
          {social.platform === 'youtube' && <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>}
          {social.platform === 'blog' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1M19 20a2 2 0 002-2V8a2 2 0 00-2-2h-2M19 20H9a2 2 0 01-2-2v-5a2 2 0 012-2h10a2 2 0 012 2v5a2 2 0 01-2 2zM7 8h6v2H7V8zm0 4h3v2H7v-2z"/></svg>}
        </a>
      ))}
    </div>

    <p class="text-xs text-gray-500 font-medium">{footerConfig.copyrightNotice}</p>
  </div>
</footer>