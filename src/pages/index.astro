---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import { getCollection } from 'astro:content';

// Fetch entry folders from src/content/
const cmsServices = await getCollection('services');
const cmsChronicles = await getCollection('chronicles');
const cmsPartners = await getCollection('partners');

// Safely access data layers and sort chronicles by year descending
const sortedChronicles = cmsChronicles.sort((a, b) => {
  const yearB = b.data?.year || '';
  const yearA = a.data?.year || '';
  return yearB.localeCompare(yearA);
});

// Duplicate the array to create a seamless infinite loop illusion
const scrollingPartners = [...cmsPartners, ...cmsPartners, ...cmsPartners];
---
<BaseLayout title="OG Recreations - The Original Stress Buster">
  <HeroSlider />

  <!-- 3 Pillars of Excellence -->
  <section class="py-20 bg-white" id="services">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-brand-blue">Our Three Pillars of Excellence</h2>
        <div class="h-1 w-24 bg-brand-gold mx-auto mt-4 mb-4 rounded-full"></div>
        <p class="text-gray-600 text-sm font-medium">Premium recreational design mapping literature, executive development milestones, and professional event hosting.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {cmsServices.map((srv, idx) => (
          <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 flex flex-col justify-between group">
            <div>
              <div class="h-48 w-full relative bg-brand-blue overflow-hidden shrink-0">
                <img src={srv.data.image} alt={srv.data.title} class="w-full h-full object-cover opacity-75 group-hover:scale-103 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-brand-blue/20 to-transparent"></div>
                <div class="absolute bottom-4 left-6">
                  <span class="bg-brand-gold text-brand-blue font-mono text-[11px] font-bold px-2 py-0.5 rounded shadow-sm">PILLAR 0{idx+1}</span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="font-serif text-2xl font-bold text-brand-blue mb-4">{srv.data.title}</h3>
                <ul class="space-y-2 text-xs sm:text-sm text-gray-600 font-medium">
                  {srv.data.subServices && srv.data.subServices.slice(0, 4).map((sub) => (
                    <li class="flex items-center gap-2">
                      <span class="w-1.5 h-1.5 rounded-full bg-brand-gold"></span>
                      {sub.subServiceTitle}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            <div class="px-6 pb-6 mt-auto">
              <a href={`/og-recreations/services/${srv.data.slugId || srv.slug}`} class="text-brand-blue hover:text-brand-gold font-bold text-xs inline-flex items-center gap-1 border-t border-gray-100 pt-4 w-full justify-between transition-colors">
                Explore Roster Capabilities
                <svg class="w-3 h-3 text-brand-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Horizontal Chronicles System -->
  <section class="py-20 bg-gradient-to-b from-[#081b33] to-brand-blue text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
        <div>
          <span class="text-brand-gold uppercase tracking-widest text-xs font-bold block mb-2 font-mono">Legacy & Live Milestones</span>
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white tracking-wide">Chronicles of Our Past</h2>
          <div class="h-1 w-20 bg-brand-gold mt-3 rounded-full"></div>
        </div>
      </div>

      <div class="relative pt-8">
        <div class="absolute top-[48px] left-4 right-4 h-0.5 bg-gradient-to-r from-brand-gold/10 via-brand-gold/60 to-brand-gold/10 hidden md:block z-0"></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
          {sortedChronicles.map((event) => (
            <div class="group">
              <div class="hidden md:flex items-center justify-center mb-6">
                <div class="w-4 h-4 rounded-full bg-brand-blue border-2 border-brand-gold shadow-md group-hover:bg-brand-gold group-hover:scale-125 transition-all duration-300"></div>
              </div>
              <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl overflow-hidden shadow-xl hover:border-brand-gold/40 transition-all duration-300 transform hover:-translate-y-1">
                <div class="h-36 w-full relative bg-brand-blue">
                  <img src={event.data.image} alt={event.data.title} class="w-full h-full object-cover opacity-60" />
                  <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-transparent to-transparent"></div>
                  <span class="absolute top-3 left-3 bg-brand-gold text-brand-blue text-[10px] font-mono font-bold px-2.5 py-0.5 rounded shadow-sm">{event.data.month} {event.data.year}</span>
                </div>
                <div class="p-5">
                  <h3 class="font-serif text-lg font-bold text-brand-gold mb-1.5">{event.data.title}</h3>
                  <p class="text-gray-300 text-xs leading-relaxed font-medium">{event.data.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

 <!-- Dynamic Infinite Autoscrolling Institutional Partnerships Section -->
<section class="py-20 bg-gray-50 border-t border-gray-100 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="text-brand-gold uppercase tracking-widest text-xs font-bold block mb-2 font-mono">Collaborations & Networks</span>
    <h2 class="font-serif text-3xl font-bold text-brand-blue mb-12 tracking-wide">Trusted Partnerships</h2>
    <div class="h-1 w-20 bg-brand-gold mx-auto -mt-8 mb-12 rounded-full"></div>
  </div>

  <!-- Hidden scrollbar layout wrapper -->
  <div class="w-full overflow-hidden relative group/marquee select-none">
    <!-- Left & Right Fade Overlays for Elegant Edges -->
    <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none"></div>

    <!-- Marquee Scrolling Track (Pauses on Hover) -->
    <div class="flex space-x-6 w-max animate-marquee group-hover/marquee:[animation-play-state:paused] px-4">
      {scrollingPartners.map((partner) => (
        <a 
          href={partner.data.url || '#'} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex flex-col justify-between items-center bg-white p-6 rounded-2xl border border-gray-200/80 shadow-sm hover:shadow-xl hover:border-brand-gold/60 transition-all duration-300 w-64 shrink-0 group"
        >
          <!-- Logo Zone - Rendered in Original Vibrancy Color Base -->
          <div class="h-16 w-full flex items-center justify-center mb-4">
            {partner.data.logo ? (
              <img 
                src={partner.data.logo} 
                alt={`${partner.data.title} Logo`} 
                class="max-h-full max-w-[85%] object-contain scale-100 group-hover:scale-105 transition-transform duration-300" 
              />
            ) : (
              <div class="w-10 h-10 rounded-xl bg-brand-bgLight/40 flex items-center justify-center text-brand-blue/30 group-hover:text-brand-gold/60 transition-colors duration-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
            )}
          </div>

          <!-- Title Label Zone (MODIFIED FOR HIGH READABILITY AND ANTI-TRUNCATION) -->
          <span class="block text-xs sm:text-sm font-sans font-black tracking-wide text-brand-blue group-hover:text-brand-gold transition-colors duration-300 uppercase text-center mt-auto border-t border-gray-100 pt-3 w-full break-words whitespace-normal leading-tight">
            {partner.data.title}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
</BaseLayout>

<style>
  /* Infinite Scroll CSS Keyframes configuration track */
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(calc(-33.33% - 8px)); }
  }

  .animate-marquee {
    animation: marquee 25s linear infinite;
  }
</style>