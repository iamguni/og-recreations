---
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutData from '../data/about.json';
---
<BaseLayout title="About Us - OG Recreations">
  <section class="relative py-20 bg-brand-blue text-white overflow-hidden border-b-4 border-brand-gold">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <span class="inline-block bg-brand-gold/20 text-brand-gold px-4 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase mb-4 border border-brand-gold/30">
        Architects of Recreation
      </span>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold tracking-wide">About OG Recreations</h1>
      <div class="h-1 w-24 bg-brand-gold mx-auto mt-4 rounded-full"></div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Vision & Mission Core Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-16">
        <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm p-8 flex flex-col justify-between">
          <div>
            <div class="text-3xl mb-3">👁️</div>
            <h2 class="font-serif text-2xl font-bold text-brand-blue mb-4">{aboutData.visionTitle}</h2>
            <p class="text-gray-600 text-sm leading-relaxed font-medium">{aboutData.visionText}</p>
          </div>
          {aboutData.visionImage && (
            <img src={aboutData.visionImage} alt="Vision Banner" class="w-full h-40 object-cover rounded-xl mt-6 grayscale opacity-80" />
          )}
        </div>
        
        <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm p-8 flex flex-col justify-between">
          <div>
            <div class="text-3xl mb-3">🎯</div>
            <h2 class="font-serif text-2xl font-bold text-brand-blue mb-4">{aboutData.missionTitle}</h2>
            <p class="text-gray-600 text-sm leading-relaxed font-medium">{aboutData.missionText}</p>
          </div>
          {aboutData.missionImage && (
            <img src={aboutData.missionImage} alt="Mission Banner" class="w-full h-40 object-cover rounded-xl mt-6 grayscale opacity-80" />
          )}
        </div>
      </div>

      <!-- High-End Video Showcase Dynamic Embed / Upload Node -->
      <div class="bg-brand-blue rounded-3xl p-4 shadow-2xl border border-brand-gold/30">
        <div class="aspect-video w-full rounded-2xl overflow-hidden bg-black relative">
          {aboutData.videoMode === "Upload" && aboutData.videoFile ? (
            <video 
              src={aboutData.videoFile} 
              controls 
              preload="metadata" 
              class="absolute inset-0 w-full h-full object-cover shadow-inner"
            >
              Your browser does not support local video playbacks.
            </video>
          ) : (
            <iframe 
              class="absolute inset-0 w-full h-full" 
              src={aboutData.videoUrl} 
              title="OG Recreations Video Presentation Showcase" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
            ></iframe>
          )}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>