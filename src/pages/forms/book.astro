  "Palau", "Palestine, State of", "Panama", "Papua New Guinea", "Paraguay", "Peru", "Philippines", "Pitcairn Islands", 
  "Poland", "Portugal", "Puerto Rico", "Qatar", "Reunion Island", "Romania", "Russia", "Rwanda", "Saint Helena", 
