---

<BaseLayout title="Book an Event Session - OG Recreations">
  <section class="py-12 bg-brand-bgLight">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Card Layout Wrapper Container -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
        <!-- Elegant Royal Blue Logo Header Box -->
        <div class="bg-brand-blue text-white p-8 border-b-4 border-brand-gold text-center">
          <h1 class="font-serif text-3xl font-bold tracking-wide">Book Our Services</h1>
          <p class="text-brand-gold text-xs font-medium tracking-widest uppercase mt-2">
            The Original Stress Buster — Secure Custom Rosters for Your Next Stage
          </p>
        </div>

        <!-- Submission Booking Form (MODIFIED WITH POST AND TARGET METHOD FOR IFRAME BRIDGE) -->
        <form 
          id="app-script-booking-form" 
          class="p-8 space-y-6" 
          action={import.meta.env.PUBLIC_APPS_SCRIPT_URL}
          method="POST"
          target="form-response-bridge"
        >
          <input type="hidden" name="pageUrl" value="/og-recreations/book" />

          <!-- 1. Selection Matrix Column Grid -->
          <div>
            <label class="block text-sm font-bold text-brand-blue mb-3">Want to book *</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {eventOptions.map((option) => (
                <label class="flex items-center gap-2.5 p-3 border border-gray-200 rounded-xl cursor-pointer hover:bg-brand-bgLight hover:border-brand-gold/60 transition bg-gray-50/40">
                  <input type="radio" name="wantToBook" value={option} required class="w-4 h-4 text-brand-blue focus:ring-brand-blue border-gray-300" />
                  <span class="text-xs font-semibold text-gray-700">{option}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- 2. Timelines & Commercial Parameters -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Expected Date *</label>
              <input type="date" name="expectedDate" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Expected Budget *</label>
              <input type="text" name="expectedBudget" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="e.g. INR 1,50,000" />
            </div>
          </div>

          <!-- 3. Full Geographic Location Form Group Matrix -->
          <div class="bg-gray-50/50 border border-gray-200 rounded-xl p-5 space-y-4">
            <h3 class="text-xs uppercase font-bold tracking-widest text-brand-blue font-mono border-b border-gray-200 pb-2">Venue Geographic Target Details</h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1">City *</label>
                <input type="text" name="city" required class="w-full rounded-lg bg-white border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="e.g. Noida / Ghaziabad" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1">State / Province</label>
                <input type="text" name="stateProvince" class="w-full rounded-lg bg-white border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="e.g. Uttar Pradesh" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1">ZIP / Postal Code</label>
                <input type="text" name="zipPostalCode" class="w-full rounded-lg bg-white border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="e.g. 201014" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1">Country *</label>
                <select name="country" required class="w-full rounded-lg bg-white border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue font-medium text-gray-700">
                  {countries.map((c) => (
                    <option value={c} selected={c === "India"}>{c}</option>
                  ))}
                </select>
              </div>
            </div>
          </div>

          <!-- 4. Client Point of Contact Matrix Info -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Name</label>
              <input type="text" name="clientName" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="Contact Person Name" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Phone *</label>
              <input type="tel" name="phone" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="Primary phone matrix contact" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address <span class="text-xs text-gray-400 font-normal">(If Any)</span></label>
              <input type="email" name="email" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" placeholder="corporate@domain.com" />
            </div>
          </div>

          <!-- 5. Open Notes / Special Instructions Area -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Any other details you would like to mention</label>
            <textarea name="otherDetails" rows="4" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-gray-400" placeholder="Elaborate regarding audience details, specific preferred artist profiles, or theme constraints..."></textarea>
          </div>

          <!-- Server Response Interactive Triggers -->
          <div id="booking-alert-success" class="hidden p-4 rounded-xl bg-emerald-50 text-emerald-800 text-xs font-semibold border border-emerald-200">
            ✓ Success! Your event hosting inquiry has been received. Our team will review the details and get back to you with a proposal shortly.
          </div>
          <div id="booking-alert-error" class="hidden p-4 rounded-xl bg-rose-50 text-rose-800 text-xs font-semibold border border-rose-200">
            ✕ Something went wrong on our end. Please double-check your fields and give it another shot.
          </div>

          <!-- Action Submission Trigger Button -->
          <div class="pt-2">
            <button 
              type="submit" 
              id="submit-booking-btn"
              class="w-full bg-brand-blue hover:bg-brand-lightBlue text-white font-bold py-3.5 px-6 rounded-lg transition-all duration-300 shadow-md tracking-wider uppercase text-xs border border-brand-gold/40 flex items-center justify-center gap-2"
            >
              Submit Request
            </button>
          </div>
        </form>
      </div>

    </div>
  </section>

  <!-- 📡 Hidden Iframe Response Receiver Bridge Element -->
  <iframe name="form-response-bridge" id="form-response-bridge" title="Form execution frame container" hidden></iframe>

  <!-- Form Submission Scripts Pipeline Logic -->
  <script is:inline>
    const form = document.getElementById('app-script-booking-form');
    const btn = document.getElementById('submit-booking-btn');
    const successAlert = document.getElementById('booking-alert-success');
    const errorAlert = document.getElementById('booking-alert-error');
    const iframeBridge = document.getElementById('form-response-bridge');

    let isSubmitting = false;

    // 1. Capture Form Submission Trigger Event
    form?.addEventListener('submit', () => {
      isSubmitting = true;
      btn.disabled = true;
      btn.innerHTML = `<svg class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Submitting your booking request...`;
      successAlert.classList.add('hidden');
      errorAlert.classList.add('hidden');
    });

    // 2. Capture Iframe load state to cleanly confirm successful transmission completion
    iframeBridge?.addEventListener('load', () => {
      if (isSubmitting) {
        isSubmitting = false;
        btn.disabled = false;
        btn.innerText = "Submit Request";
        
        // Trigger success view state updates
        successAlert.classList.remove('hidden');
        form.reset();
      }
    });
  </script>
</BaseLayout>