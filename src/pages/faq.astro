---
import BaseLayout from '../layouts/BaseLayout.astro';
import communicationData from '../data/communication.json';

// Dynamic formatting for call actions
const callLink = `tel:${communicationData.callNumber ? communicationData.callNumber.replace(/\s+/g, '') : ''}`;

// Structured FAQ Matrix data group
const faqCategories = [
  {
    categoryTitle: "Events & Bookings",
    questions: [
      {
        q: "How do I book an event with OG Recreations?",
        a: "You can easily initiate a booking by clicking the floating 'Book Now' button on our website or heading straight to our booking form. Alternatively, feel free to reach out via WhatsApp or call our support line directly to discuss dates, scope, and specific lineup curated requirements."
      },
      {
        q: "What types of events do you curate?",
        a: "We curate a vast scale of cultural assemblies including traditional Kavi Sammelans, Mushairas, corporate stress-buster poetry recitals, corporate team engagement festivals, campus cultural celebrations, and custom live theatrical musical scripts."
      },
      {
        q: "How far in advance should we book a poet or group?",
        a: "To guarantee availability for renowned headline artists, we strongly recommend reserving your date 4 to 6 weeks in advance. However, we also support accelerated processing paths for urgent corporate requirements whenever possible."
      }
    ]
  },
  {
    categoryTitle: "Poets & Performances",
    questions: [
      {
        q: "Can we request specific genres of poetry for our event?",
        a: "Absolutely. We specialize in tailoring lineups across diverse literary formats including traditional Ghazals, punchy rhythmic Muktaks, engaging Hasya (satirical comedy) verse, and deep philosophical compositions."
      },
      {
        q: "I am a poet; how can I get empanelled with OG Recreations?",
        a: "We are always looking to feature exceptional literary talents. Head directly over to our 'Join Us' page and submit your comprehensive creative profile, professional recitals links, and writing portfolio. Our institutional curation committee reviews applications periodically."
      }
    ]
  },
  {
    categoryTitle: "Corporate & Technical Solutions",
    questions: [
      {
        q: "Do you handle the complete stage setup and audio management?",
        a: "Yes, we provide end-to-end event management, which can include sound systems, stage layout consultancy, emcee transitions management, and total technical orchestration depending on your chosen service tier."
      },
      {
        q: "Are virtual/online poetry sessions available?",
        a: "Yes, we curate interactive, high-definition digital streams and virtual corporate sessions designed specifically to drive employee engagement across distributed or remote teams."
      }
    ]
  }
];
---

<BaseLayout title="Frequently Asked Questions - OG Recreations">
  <!-- Top Header Hero Block Banner -->
  <div class="bg-gradient-to-br from-brand-blue via-[#0c233f] to-[#061527] text-white py-16 border-b border-brand-gold/20 text-center px-4 relative overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10">
      <span class="text-brand-gold uppercase tracking-widest text-xs font-bold font-mono block mb-2">Support Knowledge Base</span>
      <h1 class="font-serif text-3xl sm:text-5xl font-bold tracking-wide mb-4">Frequently Asked Questions</h1>
      <div class="h-1 w-20 bg-brand-gold mx-auto rounded-full mb-4"></div>
      <p class="text-sm text-gray-400 max-w-xl mx-auto leading-relaxed font-medium">
        Find quick operational answers regarding corporate event curation, literary bookings, artist empanellment, and system solutions.
      </p>
    </div>
  </div>

  <!-- Content Section Stack Layout Container -->
  <section class="py-16 bg-gray-50 text-gray-700 min-h-[60vh]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      
      {faqCategories.map((cat, catIdx) => (
        <div class="space-y-4">
          <!-- Cluster Category Section Title -->
          <h2 class="font-serif text-lg sm:text-xl font-bold text-brand-blue/80 tracking-wide uppercase border-l-4 border-brand-gold pl-3 mb-6">
            {cat.categoryTitle}
          </h2>

          <!-- Collapsible Accordion Group Stack -->
          <div class="space-y-3">
            {cat.questions.map((item, itemIdx) => {
              const uniqueId = `faq-${catIdx}-${itemIdx}`;
              return (
                <div class="bg-white border border-gray-200/80 rounded-2xl shadow-sm overflow-hidden transition-all duration-300 hover:border-brand-gold/40">
                  <button
                    type="button"
                    class="w-full text-left p-5 flex items-center justify-between gap-4 focus:outline-none group select-none faq-toggle-btn"
                    data-target={uniqueId}
                  >
                    <span class="font-sans font-bold text-sm sm:text-base text-brand-blue group-hover:text-brand-gold transition-colors duration-200 pr-2">
                      {item.q}
                    </span>
                    <span class="p-1 bg-gray-50 rounded-lg group-hover:bg-brand-bgLight text-brand-blue/50 group-hover:text-brand-gold transition-colors shrink-0">
                      <svg class="w-4 h-4 transform transition-transform duration-300 arrow-icon" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                      </svg>
                    </span>
                  </button>
                  
                  <div 
                    id={uniqueId} 
                    class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out bg-gray-50/50"
                  >
                    <div class="p-5 border-t border-gray-100 text-xs sm:text-sm font-medium text-gray-600 leading-relaxed">
                      {item.a}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}

      <!-- Secondary Help Content Sticky Desk Box -->
      <div class="bg-white border border-brand-gold/20 rounded-3xl p-6 sm:p-8 shadow-sm text-center max-w-2xl mx-auto mt-16">
        <h3 class="font-serif text-lg sm:text-xl font-bold text-brand-blue mb-2">Still Have Questions?</h3>
        <p class="text-xs sm:text-sm text-gray-500 mb-6 font-medium">If your specific operational concern is not listed above, our central administrative desk is available to assist.</p>
        <div class="flex flex-wrap items-center justify-center gap-4 text-xs font-bold">
          <a href="/og-recreations/forms/contact" class="px-5 py-3 bg-brand-blue text-white rounded-xl hover:bg-brand-blue/90 shadow-sm transition">
            Contact Support Desk
          </a>
          {communicationData.callNumber && (
            <a href={callLink} class="px-5 py-3 border border-brand-blue text-brand-blue rounded-xl hover:bg-brand-blue hover:text-white transition">
              Call Direct Helpdesk
            </a>
          )}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  // Native high-performance vanilla script handling accordion transitions smoothly
  const toggleButtons = document.querySelectorAll('.faq-toggle-btn');

  toggleButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const contentPanel = document.getElementById(targetId);
      const arrowIcon = btn.querySelector('.arrow-icon');

      if (contentPanel && arrowIcon) {
        const isOpen = contentPanel.style.maxHeight && contentPanel.style.maxHeight !== '0px';

        // Close any currently open siblings for clean presentation feel
        if (!isOpen) {
          contentPanel.style.maxHeight = contentPanel.scrollHeight + 'px';
          arrowIcon.classList.add('rotate-180');
          btn.classList.add('bg-brand-bgLight/20');
        } else {
          contentPanel.style.maxHeight = '0px';
          arrowIcon.classList.remove('rotate-180');
          btn.classList.remove('bg-brand-bgLight/20');
        }
      }
    });
  });
</script>