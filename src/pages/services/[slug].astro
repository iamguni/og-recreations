---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allServicesEntries = await getCollection('services');
  return allServicesEntries.map(entry => ({
    params: { slug: entry.data.slugId },
    props: { service: entry.data },
  }));
}

const { service } = Astro.props;
---
<BaseLayout title={`${service.title} - OG Recreations`}>
  <section class="relative py-24 bg-brand-blue text-white overflow-hidden border-b-4 border-brand-gold">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style={`background-image: url('${service.image}');`}></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-blue via-brand-blue/90 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="inline-block bg-brand-gold/20 text-brand-gold px-4 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase mb-4 border border-brand-gold/30 font-mono">Dynamic Service Core</span>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold tracking-wide">{service.title}</h1>
      <div class="h-1 w-24 bg-brand-gold mt-4 mb-4 rounded-full"></div>
      <p class="max-w-3xl text-gray-300 text-sm sm:text-base leading-relaxed font-medium">{service.description}</p>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        {service.subServices.map((sub) => (
          <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 flex flex-col md:flex-row group">
            {sub.subServiceImage && (
              <div class="md:w-5/12 relative min-h-[240px] md:min-h-full overflow-hidden shrink-0 bg-brand-blue">
                <img src={sub.subServiceImage} alt={sub.subServiceTitle} class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-all duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-brand-blue/30 to-transparent"></div>
                <div class="absolute bottom-4 left-4 right-4 text-white">
                  <span class="text-[9px] uppercase tracking-widest bg-brand-gold text-brand-blue px-2 py-0.5 rounded font-bold inline-block mb-1">{sub.subServiceTagline || 'Featured Segment'}</span>
                  {sub.energyVibe && <div class="text-[11px] text-gray-200 font-medium">Vibe: <span class="text-white font-bold">{sub.energyVibe}</span></div>}
                </div>
              </div>
            )}
            <div class="md:w-7/12 p-6 sm:p-8 flex flex-col justify-between bg-white">
              <div>
                <h3 class="font-serif text-2xl font-bold text-brand-blue mb-3">{sub.subServiceTitle}</h3>
                <p class="text-gray-600 text-xs sm:text-sm font-medium leading-relaxed mb-5">{sub.subServiceBrief}</p>
                {sub.deliveryMetrics && (
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {sub.deliveryMetrics.map((feat) => (
                      <span class="bg-brand-bgLight text-brand-blue text-[10px] font-bold px-2.5 py-1 rounded border border-brand-lightBlue/5">✓ {feat}</span>
                    ))}
                  </div>
                )}
                {sub.focusBadges && (
                  <div class="flex flex-wrap gap-1 mt-2">
                    {sub.focusBadges.map((badge) => (
                      <span class="bg-gray-100 text-gray-700 text-[9px] font-bold px-2.5 py-1 rounded-full">#{badge}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="pt-4 border-t border-gray-100 flex items-center justify-between mt-6">
                <span class="text-[10px] font-mono text-gray-400">{sub.targetAudience ? `Target: ${sub.targetAudience}` : 'Premium Execution'}</span>
                <a href="/og-recreations/forms/book" class="bg-brand-blue text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-brand-gold hover:text-brand-blue transition border border-brand-gold/10 shadow-sm">Book Roster</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>