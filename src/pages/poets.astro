---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Safely gather all split JSON poet data records from your target content directory folder
const listPoetsContent = await getCollection('poets');
const listPoets = listPoetsContent.map(entry => entry.data);
---


<BaseLayout title="Renowned Poets Registry - OG Recreations">
  <!-- Top Banner Section -->
  <div class="bg-gradient-to-br from-brand-blue via-[#0c233f] to-[#061527] text-white py-16 border-b border-brand-gold/20 relative overflow-hidden">
    <div class="max-w-4xl mx-auto text-center px-4 relative z-10">
      <span class="text-brand-gold uppercase tracking-widest text-xs font-bold font-mono block mb-2">Literary Roster</span>
      <h1 class="font-serif text-3xl sm:text-5xl font-bold tracking-wide mb-4">Renowned Poets Directory</h1>
      <div class="h-1 w-20 bg-brand-gold mx-auto rounded-full mb-4"></div>
      <p class="text-gray-300 text-sm sm:text-base max-w-2xl mx-auto font-medium">Celebrating elite voices spanning classic Ghazals, modern Muktaks, and impactful rhythmic recitations.</p>
    </div>
  </div>

  <section class="py-16 bg-gray-50 flex-grow min-h-[50vh]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Instant Search Filter Input Field -->
      <div class="max-w-xl mx-auto mb-12 relative">
        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-gray-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <input 
          type="text" 
          id="poet-search-box" 
          placeholder="Search legendary poets by name, pseudonym or genre specialty..." 
          class="w-full pl-12 pr-4 py-3.5 bg-white border border-gray-200 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold text-sm font-medium transition-all"
        />
      </div>

      <!-- No Results Alert -->
      <div id="no-results-alert" class="hidden text-center py-12 bg-white rounded-3xl border border-gray-100 shadow-sm max-w-md mx-auto">
        <div class="w-12 h-12 bg-brand-bgLight text-brand-gold rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <p class="text-brand-blue font-serif font-bold text-base">No Matching Poets Found</p>
        <p class="text-gray-500 text-xs mt-1">Try checking for typos or searching by platform style specialty.</p>
      </div>

      <!-- Grid Cards Layout Track -->
      <div id="poets-grid-layout" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {listPoets.map((poet) => {
          const name = poet.title || "";
          const penName = poet.penName || "";
          const specialty = poet.specialty || "";
          const bio = poet.bio || "";
          
          // Image verification with standard path normalization
          const rawImg = poet.image;
          const hasPhoto = rawImg && rawImg.trim() !== "";
          
          let computedImgSrc = "";
          if (hasPhoto) {
            computedImgSrc = rawImg.startsWith('http') || rawImg.startsWith('/og-recreations') 
              ? rawImg 
              : `${rawImg.startsWith('/') ? '' : '/'}${rawImg}`;
          }

          return (
            <div 
              class="poet-card-item bg-white border border-gray-200/80 rounded-3xl p-6 shadow-md hover:shadow-xl transition-all duration-300 flex flex-col justify-between group"
              data-searchable-string={`${name.toLowerCase()} ${penName.toLowerCase()} ${specialty.toLowerCase()}`}
            >
              <div>
                <!-- Portrait Block Node (Renders image if true, fallback SVG icon if false) -->
                <div class="w-24 h-24 rounded-2xl overflow-hidden shadow-md mb-5 shrink-0 border border-brand-gold/20 mx-auto md:mx-0 flex items-center justify-center bg-brand-bgLight text-brand-blue">
                  {hasPhoto ? (
                    <img 
                      src={computedImgSrc} 
                      alt={`${name} Portrait`} 
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" 
                    />
                  ) : (
                    <svg class="w-12 h-12 text-brand-blue/40 group-hover:text-brand-gold/60 transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  )}
                </div>

                <!-- Biography Context Info Meta -->
                <div class="text-center md:text-left">
                  <div class="mb-2">
                    <h2 class="font-serif text-xl font-bold text-brand-blue group-hover:text-brand-gold transition-colors inline-block">
                      {name}
                    </h2>
                    {penName && (
                      <span class="block md:inline-block text-xs font-serif italic text-brand-gold font-bold md:ml-2">
                        ("{penName}")
                      </span>
                    )}
                  </div>
                  <span class="inline-block bg-brand-blue/5 text-brand-blue border border-brand-blue/10 text-[11px] font-mono font-bold px-2.5 py-0.5 rounded-md mb-4 uppercase">
                    {specialty}
                  </span>
                  <p class="text-gray-600 text-xs sm:text-sm leading-relaxed font-medium">
                    {bio}
                  </p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Fast Client-Side Realtime Search Processing Logic
  const searchBox = document.getElementById('poet-search-box') as HTMLInputElement;
  const cardItems = document.querySelectorAll('.poet-card-item');
  const noResultsAlert = document.getElementById('no-results-alert');
  const gridLayout = document.getElementById('poets-grid-layout');

  if (searchBox && cardItems.length > 0) {
    searchBox.addEventListener('input', (e) => {
      const searchTerm = (e.target as HTMLInputElement).value.toLowerCase().trim();
      let visibleCount = 0;

      cardItems.forEach((card) => {
        const itemElement = card as HTMLElement;
        const searchTarget = itemElement.getAttribute('data-searchable-string') || '';
        
        if (searchTarget.includes(searchTerm)) {
          itemElement.style.display = 'flex';
          visibleCount++;
        } else {
          itemElement.style.display = 'none';
        }
      });

      if (visibleCount === 0) {
        noResultsAlert?.classList.remove('hidden');
        gridLayout?.classList.add('opacity-0');
      } else {
        noResultsAlert?.classList.add('hidden');
        gridLayout?.classList.remove('opacity-0');
      }
    });
  }
</script>