---
import brandingData from '../data/branding.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import FloatingBookButton from '../components/FloatingBookButton.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css'; // Adjust path based on your design system

const { title } = Astro.props;

// Determine dynamic favicon path fallback matching GitHub Pages sub-directories
const rawFavicon = brandingData?.favicon;
const computedFaviconSrc = rawFavicon
  ? (rawFavicon.startsWith('http') || rawFavicon.startsWith('/og-recreations') 
    ? rawFavicon 
    : `${rawFavicon.startsWith('/') ? '' : '/'}${rawFavicon}`)
  : '/favicon.svg'; // Standard absolute default fallback fallback
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={computedFaviconSrc} />
    <title>{title || brandingData?.title || "OG Recreations"}</title>
  </head>
  <body class="bg-white text-gray-900 flex flex-col min-h-screen font-sans">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <ScrollToTop/>
    <FloatingBookButton/>
    <CookieConsent/>
  </body>
</html>
